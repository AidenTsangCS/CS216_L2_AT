{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build all",
            "type": "shell",
            "command": "make",
            "args": ["all"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build current file",
            "type": "shell",
            "command": "mkdir -p \"${fileDirname}/build\" && clang++ -std=c++17 -Wall -Wextra -Wpedantic -g -O0 \"${file}\" -o \"${fileDirname}/build/${fileBasenameNoExtension}\"",
            "group": { "kind": "build", "isDefault": false },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build & run current file",
            "type": "shell",
            "command": "mkdir -p \"${fileDirname}/build\" && clang++ -std=c++17 -Wall -Wextra -Wpedantic -g -O0 \"${file}\" -o \"${fileDirname}/build/${fileBasenameNoExtension}\" && \"${fileDirname}/build/${fileBasenameNoExtension}\"",
            "group": { "kind": "build", "isDefault": false },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "problemMatcher": []
        }
    ]
}
